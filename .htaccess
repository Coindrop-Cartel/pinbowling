Options -MultiViews
RewriteEngine On

# Internally rewrite extensionless URLs to their .php equivalents.
# This maintains clean URLs for UI navigation (e.g., visiting /scores)
# while allowing explicit API calls to bypass these rules entirely.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]